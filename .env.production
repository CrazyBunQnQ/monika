# ==============================================================================
# Monika Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the REQUIRED values
#
# Quick setup:
#   1. cp .env.production .env
#   2. Fill in SECRET_KEY and LLM configuration below
#   3. Run: docker-compose up -d
# ==============================================================================

# ------------------------------------------------------------------------------
# REQUIRED CONFIGURATION
# ------------------------------------------------------------------------------

# JWT signing key (REQUIRED)
# Generate: openssl rand -hex 32
SECRET_KEY=change-this-secret-key-run-openssl-rand-hex-32

# ------------------------------------------------------------------------------
# LLM CONFIGURATION (REQUIRED)
# ------------------------------------------------------------------------------
# Choose your LLM provider and configure the three required settings:
#   - BASE_URL: API endpoint URL
#   - API_KEY: Your API key
#   - MODEL: Model name to use

# Which LLM provider to use? (openai, claude)
LLM_PROVIDER=openai

# OpenAI Configuration (REQUIRED if LLM_PROVIDER=openai)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Claude Configuration (REQUIRED if LLM_PROVIDER=claude)
# CLAUDE_BASE_URL=https://api.anthropic.com
# CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
# These defaults work for Docker Compose. Only change if using external DB.

DB_HOST=postgres
DB_PORT=5432
DB_NAME=monika
DB_USER=postgres
DB_PASSWORD=postgres

# ------------------------------------------------------------------------------
# OPTIONAL CONFIGURATION
# ------------------------------------------------------------------------------

# Debug mode (default: false)
# DEBUG=true

# HTTP Port (default: 80)
# Change if port 80 is already in use by other applications
# HTTP_PORT=8080

# ------------------------------------------------------------------------------
# EXAMPLES
# ------------------------------------------------------------------------------
#
# Using OpenAI with proxy:
#   OPENAI_BASE_URL=https://your-proxy.com/v1
#   OPENAI_API_KEY=sk-your-key
#   OPENAI_MODEL=gpt-4o-mini
#
# Using Azure OpenAI:
#   OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
#   OPENAI_API_KEY=your-azure-key
#   OPENAI_MODEL=gpt-4
#
# Using Claude:
#   LLM_PROVIDER=claude
#   CLAUDE_BASE_URL=https://api.anthropic.com
#   CLAUDE_API_KEY=sk-ant-your-key
#   CLAUDE_MODEL=claude-3-5-sonnet-20241022
#
# ------------------------------------------------------------------------------
