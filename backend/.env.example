# Monika Backend Configuration
# Copy this file to .env and update with your values

# ===== DATABASE CONFIGURATION =====
# Database type: sqlite or postgresql
# - sqlite: Local development (no Docker required)
# - postgresql: Production mode (requires Docker)
DB_TYPE=sqlite

# SQLite configuration (for local development)
# Database file will be created in project root
SQLITE_PATH=monika.db

# PostgreSQL configuration (for Docker/production)
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=monika
# DB_USER=postgres
# DB_PASSWORD=postgres

# ===== SECURITY (REQUIRED) =====
# JWT signing key (min 32 chars)
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-min-32-characters

# ===== LLM CONFIGURATION (REQUIRED) =====
# LLM provider to use: openai, claude
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Claude Configuration (if using claude provider)
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ===== OPTIONAL CONFIGURATION =====
# Debug mode (production: false)
DEBUG=false
